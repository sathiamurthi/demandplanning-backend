{
  "compilerOptions": {
    "target": "ES2020",

    "module": "CommonJS",
    "moduleResolution": "node",  

    "rootDir": "./backend/src",
    "outDir": "./dist",

    "typeRoots": ["./types", "./node_modules/@types"],
    "types": ["node"],
  
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["backend/src/**/*"]
}