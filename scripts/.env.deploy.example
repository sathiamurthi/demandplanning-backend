# =============================================================
# .env.deploy.example  —  Deployment secrets template
#
# SETUP:
#   Copy this file to .env.deploy (same directory) and fill values.
#   .env.deploy is gitignored — NEVER commit it.
#
# WHERE TO GET EACH TOKEN:
#   RENDER_TOKEN     → https://dashboard.render.com/u/settings  → API Keys
#   GITHUB_TOKEN     → https://github.com/settings/tokens       → PAT with repo scope
#   VERCEL_TOKEN     → https://vercel.com/account/settings/tokens
#   VERCEL_TEAM      → Your Vercel team slug (shown in URL: vercel.com/<slug>)
#   VERCEL_PROJECT_ID→ vercel.com/<team>/<project>/settings (General → Project ID)
#   RENDER_SVC_ID    → https://api.render.com/v1/services  (find your service id)
#                      or Render dashboard URL: dashboard.render.com/web/<id>
# =============================================================

RENDER_TOKEN=rnd_your_render_api_token
GITHUB_TOKEN=ghp_your_github_pat
VERCEL_TOKEN=vcp_your_vercel_token
VERCEL_TEAM=your-vercel-team-slug
VERCEL_PROJECT_ID=prj_your_vercel_project_id
RENDER_SVC_ID=srv_your_render_service_id

# Deployment target URLs (defaults work for this project)
BACKEND_URL=https://demandplanning-backend.onrender.com
FRONTEND_URL=https://demandgenius.vercel.app
