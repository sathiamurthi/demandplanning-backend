# =============================================================
# .env.deploy.example  —  Copy to .env.deploy and fill values
# .env.deploy is gitignored — never commit real secrets
# =============================================================

RENDER_TOKEN=rnd_your_render_api_token
GITHUB_TOKEN=ghp_your_github_pat
VERCEL_TOKEN=vcp_your_vercel_token
VERCEL_TEAM=your-vercel-team-slug
VERCEL_PROJECT_ID=prj_your_vercel_project_id
RENDER_SVC_ID=srv_your_render_service_id
GITHUB_REPO=yourorg/your-backend-repo
BACKEND_URL=https://your-app-backend.onrender.com
FRONTEND_URL=https://your-app.vercel.app
